#!/system/bin/sh
# rish - Ponte de comunicação Shizuku Shell Loader

# 1. Define o diretório onde a MainActivity extraiu os arquivos
BASEDIR="/data/local/tmp"
DEX="$BASEDIR/rish_shizuku.dex"

# 2. Verifica se o componente principal existe
if [ ! -f "$DEX" ]; then
  echo "Erro: rish_shizuku.dex nao encontrado em $BASEDIR"
  echo "Certifique-se de que a MainActivity inicializou os arquivos."
  exit 1
fi

# 3. Tratamento para Android 14+ (SDK 34)
# O app_process não carrega arquivos DEX que tenham permissão de escrita.
if [ $(getprop ro.build.version.sdk) -ge 34 ]; then
  if [ -w "$DEX" ]; then
    chmod 400 "$DEX"
  fi
fi

# 4. Identidade da Aplicação
# Alterado para o seu pacote para garantir que as permissões batam
export RISH_APPLICATION_ID="com.eightball.pool"

# 5. Execução do Loader
# Este comando faz a mágica de abrir o canal de comunicação Shizuku
/system/bin/app_process \
    -Djava.class.path="$DEX" \
    /system/bin \
    --nice-name=rish \
    rikka.shizuku.shell.ShizukuShellLoader "$@"
