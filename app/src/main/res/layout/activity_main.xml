<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Fundo da imagem (coloque sua imagem em res/drawable/bg_main.jpg ou .png) -->
    <ImageView
        android:id="@+id/imgBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_main"
        android:contentDescription="@null" />

    <!-- Overlay escuro para garantir legibilidade -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_overlay" />

    <!-- Conteúdo principal com ScrollView -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ═══════════════════════════════════════ -->
            <!-- HEADER: Logo + Título                   -->
            <!-- ═══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="48dp"
                android:paddingBottom="24dp"
                android:paddingHorizontal="24dp"
                android:background="@drawable/header_gradient">

                <!-- Ícone do app -->
                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@mipmap/ic_launcher"
                    android:contentDescription="@null"
                    android:layout_marginBottom="12dp" />

                <!-- Título principal YGLN Bypass Diamant -->
                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YGLN BYPASS"
                    android:textColor="#FFFFFF"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:shadowColor="#00E5FF"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="18" />

                <!-- Linha neon sob o título -->
                <View
                    android:layout_width="160dp"
                    android:layout_height="2dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="6dp"
                    android:background="@drawable/divider_neon" />

                <!-- Subtítulo: Diamant -->
                <TextView
                    android:id="@+id/tv_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✦  D I A M A N T  ✦"
                    android:textColor="#39FF14"
                    android:textSize="13sp"
                    android:letterSpacing="0.25"
                    android:shadowColor="#39FF14"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="12" />

            </LinearLayout>

            <!-- ═══════════════════════════════════════ -->
            <!-- CARD DE STATUS — Glassmorphism          -->
            <!-- ═══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:padding="20dp"
                android:background="@drawable/card_glass">

                <!-- Label STATUS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/status_dot"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/dot_neon_cyan"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="STATUS DO SISTEMA"
                        android:textColor="#00E5FF"
                        android:textSize="11sp"
                        android:letterSpacing="0.2"
                        android:textStyle="bold" />

                    <!-- Badge versão -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" v2.0 "
                        android:textColor="#39FF14"
                        android:textSize="10sp"
                        android:background="@drawable/badge_green"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp" />

                </LinearLayout>

                <!-- Texto de status obrigatório -->
                <TextView
                    android:id="@+id/txtStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="⚡ Aguardando conexão..."
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:shadowColor="#00E5FF"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="8" />

                <!-- Barra de progresso neon -->
                <ProgressBar
                    android:id="@+id/progress_bar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_marginTop="14dp"
                    android:indeterminate="true"
                    android:indeterminateTint="#00E5FF"
                    android:progressBackgroundTint="#1A3040" />

            </LinearLayout>

            <!-- ═══════════════════════════════════════ -->
            <!-- CARD DE LOGS — Terminal Neon             -->
            <!-- ═══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/card_terminal">

                <!-- Barra do terminal (botões decorativos) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="14dp"
                    android:background="@drawable/terminal_topbar">

                    <!-- Círculos decorativos tipo macOS -->
                    <View
                        android:layout_width="11dp"
                        android:layout_height="11dp"
                        android:background="@drawable/dot_red"
                        android:layout_marginEnd="7dp" />
                    <View
                        android:layout_width="11dp"
                        android:layout_height="11dp"
                        android:background="@drawable/dot_yellow"
                        android:layout_marginEnd="7dp" />
                    <View
                        android:layout_width="11dp"
                        android:layout_height="11dp"
                        android:background="@drawable/dot_green" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="LOG TERMINAL"
                        android:textColor="#39FF14"
                        android:textSize="11sp"
                        android:letterSpacing="0.18"
                        android:fontFamily="monospace" />

                </LinearLayout>

                <!-- Área de scroll dos logs -->
                <ScrollView
                    android:id="@+id/log_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:padding="14dp"
                    android:scrollbars="vertical"
                    android:scrollbarThumbVertical="@drawable/scrollbar_thumb"
                    android:fadeScrollbars="false">

                    <TextView
                        android:id="@+id/txtLogs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:text="&gt; Sistema YGLN inicializado...\n&gt; Aguardando ação do usuário_"
                        android:textColor="#39FF14"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.4"
                        android:shadowColor="#39FF14"
                        android:shadowDx="0"
                        android:shadowDy="0"
                        android:shadowRadius="6" />

                </ScrollView>

            </LinearLayout>

            <!-- ═══════════════════════════════════════ -->
            <!-- BOTÕES DE AÇÃO                          -->
            <!-- ═══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp">

                <!-- Botão Principal: BYPASS DIAMANTES -->
                <Button
                    android:id="@+id/btnBypassDiamantes"
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:background="@drawable/btn_bypass_primary"
                    android:text="💎  BYPASS DIAMANTES"
                    android:textColor="#000000"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"
                    android:elevation="12dp"
                    android:stateListAnimator="@null" />

                <!-- Separador com label -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginVertical="16dp">
                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#25FFFFFF" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  FERRAMENTAS  "
                        android:textColor="#606070"
                        android:textSize="10sp"
                        android:letterSpacing="0.2" />
                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#25FFFFFF" />
                </LinearLayout>

                <!-- Botão Upload APK -->
                <Button
                    android:id="@+id/btnUploadApk"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:background="@drawable/btn_secondary_cyan"
                    android:text="📤  UPLOAD APK"
                    android:textColor="#00E5FF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:elevation="8dp"
                    android:stateListAnimator="@null" />

            </LinearLayout>

            <!-- ═══════════════════════════════════════ -->
            <!-- RODAPÉ                                  -->
            <!-- ═══════════════════════════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center"
                android:text="✦  YGLN BYPASS DIAMANT  •  2026  ✦"
                android:textColor="#35FFFFFF"
                android:textSize="10sp"
                android:letterSpacing="0.15" />

        </LinearLayout>
    </ScrollView>

</FrameLayout>
