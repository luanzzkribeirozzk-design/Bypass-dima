<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Fundo glass semi-transparente -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#CC050E1A" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <!-- Borda neon cyan -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke android:width="1dp" android:color="#5500E5FF" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <!-- Brilho superior (topo mais claro) -->
    <item android:bottom="60dp">
        <shape android:shape="rectangle">
            <solid android:color="#0A00E5FF" />
            <corners android:topLeftRadius="18dp" android:topRightRadius="18dp"
                android:bottomLeftRadius="0dp" android:bottomRightRadius="0dp" />
        </shape>
    </item>
</layer-list>
