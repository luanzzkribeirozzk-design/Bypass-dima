<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Estado pressionado -->
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:type="linear"
                        android:angle="0"
                        android:startColor="#00B8CC"
                        android:endColor="#1FCC00" />
                    <corners android:radius="14dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <!-- Estado normal -->
    <item>
        <layer-list>
            <!-- Sombra/Glow neon -->
            <item android:left="2dp" android:top="4dp" android:right="2dp" android:bottom="0dp">
                <shape android:shape="rectangle">
                    <solid android:color="#6639FF14" />
                    <corners android:radius="14dp" />
                </shape>
            </item>
            <!-- Fundo gradiente ciano → verde neon -->
            <item android:bottom="4dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:type="linear"
                        android:angle="0"
                        android:startColor="#00E5FF"
                        android:centerColor="#00D4A0"
                        android:endColor="#39FF14" />
                    <corners android:radius="14dp" />
                </shape>
            </item>
            <!-- Reflexo superior (brilho glass) -->
            <item android:bottom="32dp">
                <shape android:shape="rectangle">
                    <solid android:color="#2AFFFFFF" />
                    <corners android:topLeftRadius="14dp" android:topRightRadius="14dp"
                        android:bottomLeftRadius="4dp" android:bottomRightRadius="4dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
